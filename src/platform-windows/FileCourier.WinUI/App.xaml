<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FileCourier.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 Fluent Design system resources -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.UI.Controls.DataGrid/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:StatusToBrushConverter x:Key="StatusToBrushConverter" xmlns:converters="using:FileCourier.WinUI.Converters"/>

            <!-- Brand colours -->
            <Color x:Key="BrandPrimary">#2563EB</Color>
            <Color x:Key="BrandAccent">#3B82F6</Color>
            <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}"/>
            <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccent}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
