<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="FileCourier.WinUI.Dialogs.IncomingTransferDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Incoming Transfer"
    PrimaryButtonText="Agree Once"
    SecondaryButtonText="Always Agree"
    CloseButtonText="Deny"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="360">

        <!-- Sender info -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="&#xE7F8;" FontSize="32" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="SenderName" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="SenderIp" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- File summary (visible for file transfers) -->
        <StackPanel x:Name="FileSummaryPanel" Spacing="4">
            <TextBlock x:Name="FileSummaryText" TextWrapping="Wrap"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SavePathBox" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="Change" Click="ChangePath_Click"/>
            </Grid>
        </StackPanel>

        <!-- Text payload (visible for text transfers) -->
        <StackPanel x:Name="TextPayloadPanel" Spacing="4" Visibility="Collapsed">
            <TextBlock Text="Text Message:" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="TextContentBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"/>
            <Button x:Name="CopyButton" Content="Copy to Clipboard" Click="CopyToClipboard_Click" HorizontalAlignment="Left"/>
        </StackPanel>

    </StackPanel>
</ContentDialog>
