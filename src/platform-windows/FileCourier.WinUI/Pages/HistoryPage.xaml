<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileCourier.WinUI.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:FileCourier.Core.Models"
    xmlns:converters="using:FileCourier.WinUI.Converters">

    <Page.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <RelativePanel>
            <TextBlock Text="Transfer History" Style="{StaticResource TitleTextBlockStyle}" RelativePanel.AlignLeftWithPanel="True"/>
            <Button Content="Clear All" 
                    Command="{x:Bind _vm.ClearAllCommand}"
                    RelativePanel.AlignRightWithPanel="True"
                    Style="{StaticResource AccentButtonStyle}"/>
        </RelativePanel>

        <ListView x:Name="HistoryListView" Grid.Row="1" SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:TransferHistoryRecord">
                    <Grid Padding="12" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Direction icon -->
                        <FontIcon
                            Glyph="{x:Bind local:HistoryPage.DirectionGlyph(Direction)}"
                            FontSize="24"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            xmlns:local="using:FileCourier.WinUI.Pages"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ItemName}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ItemPath}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    <Run Text="{x:Bind local:HistoryPage.FormatSize(TotalSize)}" xmlns:local="using:FileCourier.WinUI.Pages"/>
                                    <Run Text=" · "/>
                                    <Run Text="{x:Bind CounterpartyName}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Status and Date -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="4">
                            <Border CornerRadius="4" Padding="8,2" 
                                    Background="{x:Bind Status, Converter={StaticResource StatusToBrushConverter}, Mode=OneWay}"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{x:Bind Status, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="White"/>
                            </Border>
                            <TextBlock Text="{x:Bind local:HistoryPage.FormatDate(Timestamp)}" 
                                     Style="{StaticResource CaptionTextBlockStyle}" 
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                     xmlns:local="using:FileCourier.WinUI.Pages"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="{x:Bind local:HistoryPage.RetryButtonText(Status, BytesTransferred, TotalSize), Mode=OneWay}" 
                                    Visibility="{x:Bind local:HistoryPage.ShowRetry(Status, Direction), Mode=OneWay}"
                                    Command="{Binding ElementName=HistoryListView, Path=DataContext.RetryCommand}"
                                    CommandParameter="{x:Bind}"
                                    xmlns:local="using:FileCourier.WinUI.Pages"/>
                            <Button Content="Delete" 
                                    Command="{Binding ElementName=HistoryListView, Path=DataContext.DeleteRecordCommand}"
                                    CommandParameter="{x:Bind}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status Message -->
        <TextBlock Grid.Row="2" Text="{x:Bind _vm.StatusMessage, Mode=OneWay}" 
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"/>
    </Grid>
</Page>
