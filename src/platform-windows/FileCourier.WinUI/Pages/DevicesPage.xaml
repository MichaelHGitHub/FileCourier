<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FileCourier.WinUI.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:FileCourier.Core.Models"
    xmlns:local="using:FileCourier.WinUI.Pages"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:FileCourier.WinUI.Converters"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:FileNameConverter x:Key="FileNameConverter"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:IconConverter x:Key="IconConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid RowSpacing="16" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Banner -->
            <RowDefinition Height="Auto"/> <!-- Status/Refresh -->
            <RowDefinition Height="150"/>  <!-- Device List -->
            <RowDefinition Height="Auto"/> <!-- Send Text Area -->
            <RowDefinition Height="*"/>    <!-- Selected Files (Bigger) -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
            <RowDefinition Height="Auto"/> <!-- Active Transfer Banner -->
        </Grid.RowDefinitions>

        <!-- Header banner -->
        <InfoBar
            x:Name="NetworkBanner"
            Grid.Row="0"
            IsOpen="True"
            IsClosable="False"
            Severity="Informational"
            Title="Local Network"
            Message="Both sender and receiver must be connected to the same Local Area Network (Wi-Fi or LAN) to transfer files."/>

        <!-- Status bar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Text="Scanning for devices…" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button x:Name="RefreshButton" Grid.Column="1" Content="Refresh" Click="RefreshButton_Click" Margin="0,0,8,0">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="R"/>
                </Button.KeyboardAccelerators>
            </Button>
            <Button x:Name="ManualConnectButton" Grid.Column="2" Content="Connect Manually" Click="ManualConnect_Click"/>
        </Grid>

        <!-- Device list -->
        <ListView
            x:Name="DeviceListView"
            Grid.Row="2"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="DeviceListView_ItemClick"
            SelectionChanged="DeviceList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SystemDevice">
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PathIcon Data="M20,18V19H4V18H20M20,3H4C2.89,3 2,3.89 2,5V15C2,16.1 2.89,17 4,17H9V18H7V20H17V18H15V17H20C21.1,17 22,16.1 22,15V5C22,3.89 21.1,3 20,3M20,15H4V5H20V15Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind DeviceName}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <Border Background="{ThemeResource SystemFillColorSuccessBrush}" 
                                        CornerRadius="4" 
                                        Padding="6,2" 
                                        Visibility="{x:Bind IsTrusted, Converter={StaticResource BoolToVisibilityConverter}}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Trusted" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind OS}"/>
                                <Run Text=" · "/>
                                <Run Text="{x:Bind IPAddress}"/>
                            </TextBlock>
                        </StackPanel>
                        <PathIcon Grid.Column="2" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Send Text Area (Row 3) -->
        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid>
                <TextBox x:Name="TextPayloadBox" 
                         PlaceholderText="Send text or clipboard content…" 
                         AcceptsReturn="True" 
                         MaxHeight="60"
                         TextChanged="TextPayloadBox_TextChanged"/>
                <Button x:Name="ClearMessageButton" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,10,6,0"
                        Padding="4"
                        Background="Transparent" 
                        BorderThickness="0"
                        Visibility="Collapsed"
                        Click="ClearMessage_Click">
                    <FontIcon Glyph="&#xE8BB;" FontSize="12"/> <!-- Symbol: Close -->
                </Button>
            </Grid>
            <Button x:Name="SendTextButton" Grid.Column="1" Content="Send Text" VerticalAlignment="Bottom" Click="SendText_Click" IsEnabled="False"/>
        </Grid>

        <!-- Selected items list (Row 4) -->
        <controls:DataGrid
            x:Name="SelectedFilesDataGrid"
            Grid.Row="4"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            CanUserResizeColumns="True"
            GridLinesVisibility="Horizontal"
            VerticalScrollBarVisibility="Visible"
            HorizontalScrollBarVisibility="Auto">
            <controls:DataGrid.Columns>
                <controls:DataGridTemplateColumn Header="" Width="Auto">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <FontIcon Glyph="{x:Bind IsFolder, Converter={StaticResource IconConverter}}" 
                                      FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                      FontSize="14" Margin="8,0"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
                
                <controls:DataGridTextColumn Header="Name" Binding="{Binding AbsolutePath, Converter={StaticResource FileNameConverter}}" Width="*"/>
                <controls:DataGridTextColumn Header="Size" Binding="{Binding AbsolutePath, Converter={StaticResource FileSizeConverter}}" Width="Auto"/>
                
                <controls:DataGridTemplateColumn Header="Path" Width="2*">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <TextBlock Text="{x:Bind AbsolutePath}" 
                                     TextTrimming="CharacterEllipsis" 
                                     VerticalAlignment="Center"
                                     ToolTipService.ToolTip="{x:Bind AbsolutePath}"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <controls:DataGridTemplateColumn Header="Action" Width="Auto">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <Button Padding="4" Background="Transparent" BorderThickness="0" Click="RemoveFile_Click" Tag="{x:Bind}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            </Button>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Buttons Area (Row 5) -->
        <Grid Grid.Row="5" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="SelectedFilesCountText" Text="No items selected" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <HyperlinkButton x:Name="ClearAllButton" Content="Clear All" Click="ClearAll_Click" Visibility="Collapsed"/>
            </StackPanel>
            <Button x:Name="ChooseFilesButton" Grid.Column="1" Content="Choose Files" Click="ChooseFiles_Click"/>
            <Button x:Name="ChooseFoldersButton" Grid.Column="2" Content="Choose Folders" Click="ChooseFolders_Click"/>
            <Button x:Name="SendButton" Grid.Column="3" Content="Send" Style="{StaticResource AccentButtonStyle}" Click="Send_Click" IsEnabled="False"/>
        </Grid>

        <!-- Active Transfer Warning (Row 6) -->
        <InfoBar
            x:Name="ActiveTransferWarning"
            Grid.Row="6"
            IsOpen="False"
            IsClosable="False"
            Severity="Warning"
            Title="Transfer in Progress"
            Message="A file transfer is currently active. You can still send text messages, but new file transfers are paused until the current one finishes."/>

        <!-- Transfer progress overlay -->
        <Border
            x:Name="ProgressOverlay"
            Grid.Row="4" Grid.RowSpan="3"
            Visibility="Collapsed"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="32">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MinWidth="360">
                <TextBlock x:Name="ProgressTitle" Text="Sending…" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ProgressFileName" HorizontalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
                <ProgressBar x:Name="TransferProgress" Minimum="0" Maximum="100" Value="0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SpeedText" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <TextBlock x:Name="EtaText" Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}"/>
                </Grid>
                <Button x:Name="CancelButton" Content="Cancel" HorizontalAlignment="Center" Click="Cancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
